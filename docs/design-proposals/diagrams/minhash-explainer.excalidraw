    {
      "type": "text",
      "id": "result_note",
      "x": 40,
      "y": 800,
      "width": 860,
      "height": 35,
      "text": "Band 0 or Band 1 matches → Trace B passes the filter. Parquet skips row groups where no band matches.\nThe other predicates (service.name, status) eliminate false positives from low-Jaccard band collisions.",
      "originalText": "Band 0 or Band 1 matches → Trace B passes the filter. Parquet skips row groups where no band matches.\nThe other predicates (service.name, status) eliminate false positives from low-Jaccard band collisions.",

    {
      "type": "text",
      "id": "query_text",
      "x": 50,
      "y": 753,
      "width": 840,
      "height": 30,
      "text": "{ service.name=\"checkout\" && status!=error && similar_to(\"abc123\") }\n→ rewritten to: { service.name=\"checkout\" && status!=error && (band0=0xA1B2 || band1=0xC3D4 || band2=0xE5F6 || band3=0xG7H8) }",
      "originalText": "{ service.name=\"checkout\" && status!=error && similar_to(\"abc123\") }\n→ rewritten to: { service.name=\"checkout\" && status!=error && (band0=0xA1B2 || band1=0xC3D4 || band2=0xE5F6 || band3=0xG7H8) }",
      "fontSize": 11,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "middle",
      "strokeColor": "#22c55e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
